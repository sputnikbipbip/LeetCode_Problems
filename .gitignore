## Ignore Visual Studio temporary files, build results, and
## common temporary files for .NET projects

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
## Build output
# Ignore all bin/ and obj/ folders recursively
bin/
obj/
**/bin/
**/obj/
*/bin/
*/obj/

# Common project-level build folders (explicit)
LeetCodeProblems/bin/
LeetCodeProblems/obj/

# Visual Studio Code
.vscode/

# Visual Studio
.vs/

# Rider
.idea/

# NuGet
*.nupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# JetBrains Rider local history
.localhistory/

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Resharper
_ReSharper*/
*__ReSharper*/
*.DotSettings.user

# Coverage and profiling
*.coverage
*.coveragexml
*.psess
*.vsp
*.vspx

# Generated files
*.g.cs
*.g.i.cs
*.Designer.cs

# DotCover
*.dotCover

# Temporary files
*.tmp
*.temp

# Rider
.idea/

# NuGet global packages folder (optional)
.nuget/packages/

# Lock files
project.lock.json
project.fragment.lock.json

# Local user secrets and env
.env
local.settings.json

# Ignore build/test output folders created by CI/build agents
artifacts/
TestResults/

# Keep Git from tracking file mode changes on executable files
# (uncomment if you have issues on WSL/Windows)
# .gitattributes
